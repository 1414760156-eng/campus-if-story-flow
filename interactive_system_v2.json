  "mechanics": [
    {
      "id": "relationship_temperature",
      "purpose": "决定人物后续是否自然出现、提醒、修补或低温回应。",
      "player_visible": "通过对话温度、是否主动发消息、是否一起吃饭体现。",
      "mainline_safety": "不改变主线事件，只改变人物参与方式。"
    },
    {
      "id": "psychological_undercurrent",
      "purpose": "记录回避、疲劳、边界、普通生活意识等心理暗线。",
      "player_visible": "通过睡眠、未读消息、是否问清、是否说明冲突体现。",
      "mainline_safety": "不显示数值，不直接改变章节结构。"
    },
    {
      "id": "side_hook_eligibility",
      "purpose": "只有玩家见过或接触过的人物才进入支线 hook。",
      "player_visible": "玩家只看见自己经历过的人和事。",
      "mainline_safety": "避免未触发人物在晚风长聊、第六幕、终章乱入。"
    },
    {
      "id": "delayed_echo",
      "purpose": "每个关键选择追加几周后、暑期后或冬天前的后果。",
      "player_visible": "用短过场写选择如何慢慢显形。",
      "mainline_safety": "回响只改变状态和文案温度，不改变锁定事件。"
    },
    {
      "id": "resource_reward",
      "purpose": "奖励以资料、素材、记录、联系人、简历证据呈现。",
      "player_visible": "写成留下来的文件、照片、记录或一句可复用的话。",
      "mainline_safety": "不提供爽文化跳跃成功。"
    },
    {
      "id": "fatigue_boundary_pressure",
      "purpose": "防止玩家所有支线全答应也总是最优。",
      "player_visible": "表现为睡眠不足、消息回不完、错过饭局、任务挤压。",
      "mainline_safety": "只影响关系、资源质量和低完成风险。"
    },
    {
      "id": "scene_movement_lock",
      "purpose": "确保事件发生在合理场景和动线里。",
      "player_visible": "场景转场自然，不跳出武生院沉浸版空间。",
      "mainline_safety": "所有 hook 必须绑定合法 location。"
    }
  ],
